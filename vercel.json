{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "static/**",
          "templates/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "app.py" },
    { "src": "/(.*)", "dest": "app.py" }
  ]
}
